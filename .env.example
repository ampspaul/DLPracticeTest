# ============================================================
# KY-DL Practice / Sandbox Environment Variables
# ============================================================
# Copy this file to .env (git-ignored) and fill in the values
# for your local development or CI environment.
# NEVER commit real secrets to source control.
# ============================================================

# Application environment.
# Allowed values that enable practice mode: development, dev, staging, test, qa
# Values that DISABLE practice mode:         production, prod
APP_ENV=development

# (Optional) API token for the external KY-DL sandbox/practice API.
# Leave blank if no external sandbox API is configured.
KY_DL_PRACTICE_API_TOKEN=

# (Optional) Base URL for the external KY-DL sandbox/practice API.
KY_DL_PRACTICE_BASE_URL=

# (Optional) Override the default mock document used in practice mode.
# Must match one of the document_id values defined in src/identity/mock_data.py
# e.g. PRACTICE-KY-001, PRACTICE-KY-002, PRACTICE-KY-003
KY_DL_PRACTICE_MOCK_DOC_ID=